# Python
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.coverage
htmlcov/
.ruff_cache/

# Virtual environments
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Data — never commit raw downloads or processed datasets
data/raw/*
data/processed/*
!data/raw/.gitkeep
!data/processed/.gitkeep

# Generated outputs
reports/*
static/*
manuscript/*
!reports/.gitkeep

# Run artifacts
runs/
*.log

# Secrets
.env
*.key
